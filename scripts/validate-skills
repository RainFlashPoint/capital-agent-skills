#!/usr/bin/env bash
# cap 技能族结构 lint —— 可重复回归测试(纯 shell,无依赖)。
# 检查:① 每个 SKILL.md 有合法 frontmatter;② 角色名↔文件↔字典一致;
#       ③ verify checks 名↔文件↔字典一致;④ 关键共享文件存在。
# 用法:bash scripts/validate-skills   (commit 前必跑;退出码 0=通过)
set -u
cd "$(dirname "$0")/.." || exit 2
ROOT="skills"; REF="$ROOT/cap-flow/references"
fail=0
err(){ echo "  ✗ $1"; fail=$((fail+1)); }
ok(){ echo "  ✓ $1"; }

echo "== 1. 关键共享文件/目录 =="
for p in "$REF/role-routing.md" "$REF/distillation-loop.md" "$REF/runtime-adapters/codex.md" "$REF/progress-protocol.md" "$REF/task-reconnaissance.md" "$ROOT/cap-flow/scripts/cap-context-guard" "$REF/roles" "$ROOT/cap-test/checks" "$REF/templates/STATE.md" "$REF/templates/PROFILE.md"; do
  [ -e "$p" ] && ok "$p" || err "缺失:$p"
done

echo "== 2. 每个 SKILL.md frontmatter(name + description) =="
for f in "$ROOT"/*/SKILL.md; do
  head -15 "$f" | grep -qE '^name:' || err "$f 缺 name:"
  head -15 "$f" | grep -qE '^description:' || err "$f 缺 description:"
done
[ $fail -eq 0 ] && ok "全部 SKILL.md frontmatter 合法"

echo "== 3. 角色卡:文件 ↔ role-routing 字典 ↔ STATE 模板 =="
for rf in "$REF"/roles/*.md; do
  r="$(basename "$rf" .md)"
  grep -q "$r" "$REF/role-routing.md" || err "角色 '$r' 未在 role-routing.md 出现(字典/规则漏登记)"
  grep -q "$r" "$REF/templates/STATE.md" || err "角色 '$r' 未在 STATE 模板取值字典"
done
ok "角色卡交叉引用检查完成($(ls "$REF"/roles/*.md | wc -l | tr -d ' ') 个)"

echo "== 4. verify checks:文件 ↔ role-routing ↔ cap-test =="
for mf in "$ROOT"/cap-test/checks/*.md; do
  m="$(basename "$mf" .md)"
  grep -q "$m" "$REF/role-routing.md" || err "check '$m' 未在 role-routing.md"
  grep -q "$m" "$ROOT/cap-test/SKILL.md" || err "check '$m' 未被 cap-test 引用"
done
ok "verify checks 交叉引用检查完成($(ls "$ROOT"/cap-test/checks/*.md | wc -l | tr -d ' ') 个)"

echo "== 4.1 public entry vocabulary =="
grep -q '唯一公开入口' "$ROOT/cap/SKILL.md" || err "cap 未声明为唯一公开入口"
grep -q "publicSkillNames = \['cap'\]" scripts/setup-lib.mjs || err "安装器未限制为唯一公开 Skill: cap"
for internal in harvest-experience cap-flow cap-understand cap-define cap-plan cap-implement cap-test cap-review cap-release; do
  if grep -q "publicSkillNames.*$internal" scripts/setup-lib.mjs; then err "内部阶段被暴露为公开 Skill: $internal"; fi
done
for word in 项目了解 需求确认 开发计划 编码实现 测试验证 代码评审 发布上线; do
  grep -q "$word" "$ROOT/cap/SKILL.md" || err "cap 缺少公开阶段名: $word"
  grep -q "$word" "$ROOT/cap-flow/SKILL.md" || err "cap-flow 缺少公开阶段名: $word"
done
grep -q '不得要求用户调用内部技能名' "$ROOT/cap-flow/SKILL.md" || err "cap-flow 缺少内部名称隐藏纪律"
ok "公开入口与直白动作词检查完成"

echo "== 4.2 canonical stage protocol =="
for old in cap-map cap-shape cap-build cap-verify; do
  if rg -q "$old" "$ROOT" scripts README.md CLAUDE.md --glob '!validate-skills' --glob '!setup-lib.mjs' --glob '!test-setup.mjs'; then err "仍存在旧 Skill 名: $old"; fi
done
grep -q 'stage: understand | define | plan | implement | test | review | release | done' "$REF/templates/STATE.md" || err "STATE 阶段枚举未迁移"
ok "阶段协议迁移检查完成"

echo "== 4.3 progress and repository reconnaissance =="
for f in "$ROOT"/cap-{understand,define,plan,implement,test,review,release}/SKILL.md; do
  grep -q 'progress-protocol.md' "$f" || err "$f 未加载可见进度协议"
  grep -q 'task-reconnaissance.md' "$f" || err "$f 未加载任务级代码侦察协议"
done
grep -q 'task-context.md' "$ROOT/cap-flow/SKILL.md" || err "cap-flow 未要求任务级代码事实"
grep -q 'cap-context-guard' "$ROOT/cap-flow/SKILL.md" || err "cap-flow 未执行 task-context 确定性门禁"
ok "进度与代码侦察协议检查完成"

echo "== 5. 可移植自检:流程 skill 不得硬依赖 Claude 专属工具 =="
for f in "$ROOT"/*/SKILL.md; do
  # 允许出现在"降级/不依赖"语境;这里只粗查是否完全没提降级却硬用 AskUserQuestion
  if grep -q "AskUserQuestion" "$f" && ! grep -q "text_mode" "$f"; then
    err "$f 提到 AskUserQuestion 但无 text_mode 降级(违反可移植铁律)"
  fi
done
[ $fail -eq 0 ] && ok "可移植自检通过"

echo "== 6. 语言包:文件 ↔ role-routing §7 登记 =="
if [ -d "$REF/languages" ]; then
  for lf in "$REF"/languages/*.md; do
    l="$(basename "$lf" .md)"
    grep -q "languages/$l" "$REF/role-routing.md" || err "语言包 '$l' 未在 role-routing §7 登记"
    head -6 "$lf" | grep -qE '^lang:' || err "$lf 缺 lang: frontmatter"
  done
  ok "语言包检查完成($(ls "$REF"/languages/*.md 2>/dev/null | wc -l | tr -d ' ') 个)"
fi

echo "== 7. 强门禁脚本 cap-guard 随技能自包含且可执行 =="
GUARD="$ROOT/cap-flow/scripts/cap-guard"
if [ -f "$GUARD" ]; then
  [ -x "$GUARD" ] && ok "$GUARD(存在且可执行)" || err "$GUARD 不可执行(chmod +x)"
  # hook 模板的查找路径必须指向 skills/cap-flow/scripts(三种安装方式一致)
  grep -q "skills/cap-flow/scripts/cap-guard" "$REF/templates/hooks/pre-commit" \
    || err "pre-commit hook 未按 skills/cap-flow/scripts/ 查找 cap-guard(路径漂移)"
else
  err "缺失:$GUARD(强门禁脚本应随 cap-flow 技能自包含)"
fi

echo
if [ $fail -eq 0 ]; then echo "RESULT: PASS ✅"; exit 0
else echo "RESULT: $fail 项不一致 ❌(修完再 commit)"; exit 1; fi
